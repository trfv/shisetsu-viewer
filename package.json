{
  "name": "shisetsu-viewer",
  "version": "1.0.0",
  "private": false,
  "description": "Shisetsu Viewer",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/trfv/shisetsu-viewer/"
  },
  "license": "MIT",
  "author": "trfv",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.13.2",
    "@eslint/js": "10.0.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.3",
    "eslint": "10.0.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "knip": "6.25.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "typescript7": "npm:typescript@7.0.2"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "scripts": {
    "start": "npm run start:viewer",
    "start:viewer": "npm run start -w @shisetsu-viewer/viewer",
    "start:scraper": "npm run test -w @shisetsu-viewer/scraper",
    "scrape": "npm run scrape -w @shisetsu-viewer/scraper",
    "build": "npm run build:viewer",
    "build:viewer": "npm run build -w @shisetsu-viewer/viewer",
    "update:reservations": "npm run update:reservations -w @shisetsu-viewer/scraper",
    "update:institutions": "npm run update:institutions -w @shisetsu-viewer/scraper",
    "cli": "npm run cli -w @shisetsu-viewer/mcp-server --",
    "format:check:all": "prettier --check \"./packages/**/*.ts*\"",
    "format:fix:all": "prettier --write \"./packages/**/*.ts*\"",
    "lint:all": "eslint --max-warnings=0 \"./packages/**/*.ts*\"",
    "lint:fix:all": "eslint --fix \"./packages/**/*.ts*\"",
    "typecheck:all": "npm run typecheck --workspaces",
    "knip": "knip",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint",
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  }
}
