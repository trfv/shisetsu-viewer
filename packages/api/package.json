{
  "name": "@shisetsu-viewer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/worker.ts",
  "exports": {
    ".": "./src/worker.ts",
    "./db/queries": "./src/db/queries.ts",
    "./auth/auth0": "./src/auth/auth0.ts"
  },
  "scripts": {
    "typecheck": "wrangler types && tsc",
    "test": "vitest run",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply shisetsu-db --local",
    "migrate:remote": "wrangler d1 migrations apply shisetsu-db --remote"
  },
  "dependencies": {
    "@shisetsu-viewer/shared": "0.0.1",
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.5",
    "vitest": "4.1.10",
    "wrangler": "4.111.0"
  }
}
