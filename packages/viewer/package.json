{
  "name": "@shisetsu-viewer/viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@auth0/auth0-spa-js": "2.23.0",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "date-fns": "4.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wouter": "3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "msw": "2.15.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0",
    "wrangler": "4.112.0"
  },
  "scripts": {
    "start": "vite --port 3000",
    "build": "tsc && vite build",
    "serve": "vite preview --port 3000",
    "typecheck": "tsc",
    "test": "TZ=Asia/Tokyo vitest",
    "test:ci": "TZ=Asia/Tokyo vitest --run",
    "test:unit": "TZ=Asia/Tokyo vitest --run --reporter=verbose",
    "test:integration": "TZ=Asia/Tokyo vitest --run test/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:ci && npm run test:e2e",
    "coverage": "TZ=Asia/Tokyo vitest run --coverage",
    "coverage:open": "TZ=Asia/Tokyo vitest run --coverage && open coverage/index.html",
    "deploy": "wrangler deploy",
    "deploy:versions": "wrangler versions upload --assets=./dist",
    "preview": "wrangler dev"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
