{
  "name": "@shisetsu-viewer/viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@auth0/auth0-spa-js": "2.23.0",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "date-fns": "4.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wouter": "3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@swc/core": "1.15.43",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-istanbul": "4.1.8",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "msw": "2.14.6",
    "rollup-plugin-visualizer": "7.0.1",
    "vite": "8.1.3",
    "vitest": "4.1.8",
    "wrangler": "4.107.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.1"
  },
  "scripts": {
    "start": "vite --port 3000",
    "build": "node ../../node_modules/typescript7/bin/tsc && vite build",
    "build:analyze": "vite build --mode analyze",
    "serve": "vite preview --port 3000",
    "typecheck": "node ../../node_modules/typescript7/bin/tsc",
    "test": "TZ=Asia/Tokyo vitest",
    "test:ci": "TZ=Asia/Tokyo vitest --run",
    "test:unit": "TZ=Asia/Tokyo vitest --run --reporter=verbose",
    "test:integration": "TZ=Asia/Tokyo vitest --run test/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:ci && npm run test:e2e",
    "coverage": "TZ=Asia/Tokyo vitest run --coverage",
    "coverage:open": "TZ=Asia/Tokyo vitest run --coverage && open coverage/index.html",
    "deploy": "wrangler deploy",
    "deploy:versions": "wrangler versions upload --assets=./dist",
    "preview": "wrangler dev"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
